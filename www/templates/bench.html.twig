{% extends "base.html.twig" %}

{# For inclusion in the base #}
{% block     title %}{{ inscription|replace({'\r\n': " "})|slice(0, 49)|title|e("html") }}{% endblock %}
{% block longitude %}{{ longitude }}{% endblock %}
{% block  latitude %}{{ latitude }}{% endblock %}
{% block   ogimage %}{{ app.request.schemeAndHttpHost }}/image/{{ medias|first.sha1 }}{% endblock %}
{% block    oembed %}{{ bench_id }}{% endblock %}

{% block body %}
<div itemscope="" itemtype="http://schema.org/Place">
	<h2 id="benchInscription" itemprop="description">{{ inscription|nl2br }}</h2>
	{% if medias is defined %}
		{% for media in medias %}
		<div itemprop="photo" class="main">
			{% if media.mediaType == "360" %}
			<iframe class="pannellum" allowfullscreen src="/js/pannellum-2.5.7/pannellum.htm#panorama=/media/{{ media.sha1 }}&amp;autoRotate=-2&amp;autoLoad=true"></iframe>
			{% elseif media.mediaType == "pano" %}
			<iframe class="pannellum" allowfullscreen src="/js/pannellum-2.5.7/pannellum.htm#panorama=/media/{{ media.sha1 }}&amp;autoRotate=-2&amp;autoLoad=true&amp;haov=360&amp;vaov=60&amp;autoLoad=true"></iframe>
			{% elseif media.mediaType == "video" %}
			<video src="/media/{{ media.sha1 }}" width="600" controls loop></video>
			{% else %}
			<a href="{{ media.urlFull }}">
				<img src="{{ media.url }}"
					alt="{{ media.alt }}"
					width="{{ media.width}}"
					height="{{ media.height }}"
					class="proxy-image"
					loading="lazy">
			</a>
			{% endif %}
		</div>
		<span class="info">
			<ul>
				{% if media.formattedDate != "" %}
				<li><time><span class="emoji">🗓️</span> {{ media.formattedDate }}</time></li>
				{% endif %}
				{% if media.make != "" %}
				<li><span class="emoji">📷</span> <a href="/cameras/{{ media.make }}">{{ media.make }}</a> {{ media.model }}</li>
				{% endif %}
				{% if media.userName != "" %}
				<li><span class="emoji">😎</span> <a href='/user/{{ media.userID }}'>{{ media.userName }}</a></li>
				{% endif %}
				{% if media.importURL is not null %}
				<li>
					<a rel="license" href="{{ media.importURL }}" target="_blank">
						<img src="/images/cc/{{ media.licenceIcon }}"
							class="cc-icon"
							alt="{{ media.licence }}">
					</a>
				</li>
				{% else %}
				<li>
					<a rel="license" href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank">
						<img src="/images/cc/{{ media.licenceIcon }}"
							class="cc-icon"
						alt="Creative Commons Attribution Share-Alike">
					</a>
				</li>
				{% endif %}			
			</ul>
		</span>
		{% endfor %}
	{% endif %}

	<div>
		<div id="map"></div>
		{{ map_javascript( "/api/bench/", bench_id, latitude, longitude, 17, false ) }}
{#
		<script>
			const map = L.map('map', {sleepNote: false, sleepOpacity: 1})
			L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
			map.setView([{{ latitude }},{{ longitude }}], 17);
			let url = '/api/bench/{{ bench_id }}';
			const response = fetch(url).then(response => response.json()).then(response => {
				L.geoJson(response).addTo(map);
			})
		</script>
#}
	</div>
	{% if addresses is defined %}
	<div class="info">
		<address itemprop="address" itemscope="" itemtype="http://schema.org/PostalAddress">
			<span itemprop="description">
			{% for address in addresses %}
				{% if loop.index0 == 0 %}
				<span class="address">{{ address.location }}</span>
				{% else %}
				<a class="address" href="{{ address.url }}/">{{ address.location }}</a>
				{% endif %}
			{% endfor %}
			</span>
		</address>
		<p itemprop="geo" itemscope="" itemtype="http://schema.org/GeoCoordinates">
			<code id="latlong"><span 
				itemprop="latitude"  content="{{ latitude }}" >{{ latitude }}</span>,<span itemprop="longitude" content="{{ longitude }}">{{ longitude }}</span></code>
		</p>
	</div>
	{% endif %}
</div>

{% if tags is not empty %}
<div id="taglist" class="main">
		Tags:
		{% for tag in tags %}
		<a class="tag" href="/tag/{{ tag }}/">#{{ tag|title }}</a>&nbsp;
		{% endfor %}
</div>
{% endif %}

<div class="button-bar">
	<a href="/add" class="button buttonColour"><span class="emoji">➕</span> Add new bench</a>
	<a href="/edit/{{ bench_id }}" class="button buttonColour"><span class="emoji">✏️</span> Edit</a>
	{% if osmID is not null %}
	<a class="button buttonColour" href="https://www.openstreetmap.org/node/{{ osmID }}" target="_blank"><span class="emoji">🌍</span> View on OpenStreetMap</a>
	{% else %}
	<a class="button buttonColour" href="https://mapcomplete.org/benches?z=20&lat={{ latitude }}&lon={{ longitude }}#openbenches/{{ bench_id }}" target="_blank"><span class="emoji">🌍</span> Add to OpenStreetMap</a>
	{% endif %}
	<a href="/api/bench/{{ bench_id }}" class="button buttonColour"><span class="emoji">💾</span> GeoJSON</a>
	<button class="button buttonColour" type="button" id="shareButton"><span class="emoji">📤</span> Share</button>
	<a href="https://www.openbenches.org/blog/complaints-and-reports/" class="button buttonColour"><span class="emoji">⚠️</span> Report</a>
</div>

<script>
	//	Copy the URl to the clipboard.
	//	Then open the share panel if supported.
	var shareButton = document.getElementById("shareButton");
	shareButton.onclick = function() {
		navigator.clipboard.writeText(window.location.href);
		shareButton.innerHTML = '<span class="emoji">📋</span> Copied';
		if (navigator.share) {
			navigator.share({
				url: ''
			}).then(() => {
				shareButton.innerHTML = '<span class="emoji">💬</span> Shared';
			})
			.catch( console.error );
		}
	}
</script>

<fieldset id="sharing" style="display:none;">

	<a href="https://www.facebook.com/sharer/sharer.php?u={{ app.request.uri|url_encode }}" target="_blank">
		<img src="/images/svg/facebook.svg" class="share" alt="Share on Facebook" loading="lazy">
	</a>

	<a href="https://twitter.com/intent/tweet?url={{ app.request.uri|url_encode }}&via=openbenches" target="_blank">
		<img src="/images/svg/twitter.svg" class="share" alt="Share on Twitter" loading="lazy">
	</a>

	<a href="https://api.whatsapp.com/send?text={{ app.request.uri|url_encode }}" target="_blank">
		<img src="/images/svg/whatsapp.svg" class="share" alt="Share on Whatsapp" loading="lazy">
	</a>

	<a href="mailto:?&body={{ app.request.uri|url_encode }}" target="_blank">
		<img src="/images/svg/gmail.svg" class="share" alt="Share on email" loading="lazy">
	</a>

	<a href="https://telegram.me/share/url?url={{ app.request.uri|url_encode }}" target="_blank">
		<img src="/images/svg/telegram.svg" class="share" alt="Share on Telegram" loading="lazy">
	</a>

</fieldset>

{% include 'searchform.html.twig' %}

<script src="/commentics/embed.js"></script>
<div id="commentics"></div>

{% endblock %}
